<div class="min-h-screen bg-gradient-to-b from-blue-50 to-white flex flex-col justify-center py-12 px-4 sm:px-6 lg:px-8">
  <div class="sm:mx-auto sm:w-full sm:max-w-md">
    <!-- Progress indicator -->
    <div class="flex justify-center mb-8">
      <div class="flex items-center space-x-2">
        <div class="w-3 h-3 rounded-full bg-blue-600"></div>
        <div class="w-8 h-1 bg-blue-600 rounded"></div>
        <div class="w-3 h-3 rounded-full bg-blue-600"></div>
        <div class="w-8 h-1 bg-gray-300 rounded"></div>
        <div class="w-3 h-3 rounded-full bg-gray-300"></div>
      </div>
    </div>

    <!-- Location message -->
    <div class="text-center mb-8">
      <span class="text-6xl mb-4 block">📍</span>
      <h1 class="text-2xl font-bold text-gray-900 mb-2">
        <%= t('onboarding.location.title', default: 'Chon khu vuc') %>
      </h1>
      <p class="text-gray-600">
        <%= t('onboarding.location.subtitle', default: 'Ban dang o dau tai Han Quoc?') %>
      </p>
    </div>

    <!-- Location options -->
    <div class="bg-white shadow-lg rounded-xl p-6">
      <%= form_with url: onboarding_path(step: 2), method: :patch, local: true do %>
        <div class="grid grid-cols-2 gap-3">
          <% [
            ['seoul', 'Seoul', '서울'],
            ['gyeonggi', 'Gyeonggi', '경기'],
            ['incheon', 'Incheon', '인천'],
            ['busan', 'Busan', '부산'],
            ['daegu', 'Daegu', '대구'],
            ['daejeon', 'Daejeon', '대전'],
            ['gwangju', 'Gwangju', '광주'],
            ['ulsan', 'Ulsan', '울산']
          ].each do |code, name_en, name_ko| %>
            <label class="block cursor-pointer">
              <input type="radio" name="location_code" value="<%= code %>" class="peer hidden" <%= 'checked' if current_user.location_code == code %>>
              <div class="flex flex-col items-center justify-center p-4 border-2 rounded-lg peer-checked:border-blue-500 peer-checked:bg-blue-50 hover:border-gray-400 transition-all min-h-[80px]">
                <div class="font-medium text-gray-900"><%= name_en %></div>
                <div class="text-sm text-gray-500"><%= name_ko %></div>
              </div>
            </label>
          <% end %>
        </div>

        <div class="mt-6 space-y-3">
          <button type="submit" class="w-full flex justify-center py-3 px-4 border border-transparent rounded-lg shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-all">
            <%= t('onboarding.continue', default: 'Tiep tuc') %>
          </button>

          <%= link_to onboarding_path(step: 1), class: "w-full flex justify-center py-3 px-4 border border-gray-300 rounded-lg shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 transition-all" do %>
            <%= t('onboarding.back', default: 'Quay lai') %>
          <% end %>
        </div>
      <% end %>

      <!-- Skip option -->
      <div class="mt-4 text-center">
        <%= link_to skip_onboarding_path, method: :post, class: "text-sm text-gray-500 hover:text-gray-700" do %>
          <%= t('onboarding.skip', default: 'Bo qua') %>
        <% end %>
      </div>
    </div>
  </div>
</div>
