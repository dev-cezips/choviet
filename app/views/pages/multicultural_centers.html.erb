<div class="max-w-4xl mx-auto px-4 py-12">
  <h1 class="text-3xl font-bold mb-4"><%= t('multicultural_centers.title') %></h1>
  <p class="text-gray-600 mb-8"><%= t('multicultural_centers.description') %></p>

  <!-- Emergency Hotline -->
  <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-8">
    <div class="flex items-center gap-3">
      <div class="text-2xl">🆘</div>
      <div>
        <p class="font-semibold text-red-800"><%= t('multicultural_centers.emergency.title') %></p>
        <p class="text-red-700">
          <a href="tel:1577-1366" class="font-bold text-lg hover:underline">1577-1366</a>
          <span class="text-sm ml-2">(<%= t('multicultural_centers.emergency.available_24h') %>)</span>
        </p>
      </div>
    </div>
  </div>

  <!-- Centers List -->
  <div class="space-y-6">
    <!-- Seoul Region -->
    <section>
      <h2 class="text-xl font-semibold mb-4 flex items-center gap-2">
        <span>🏛️</span>
        <%= t('multicultural_centers.regions.seoul') %>
      </h2>

      <div class="grid gap-4">
        <!-- Guro -->
        <div class="bg-white border border-gray-200 rounded-lg p-4 hover:shadow-md transition-shadow">
          <div class="flex justify-between items-start">
            <div>
              <h3 class="font-semibold text-lg"><%= t('multicultural_centers.centers.guro.name') %></h3>
              <p class="text-gray-600 text-sm mt-1"><%= t('multicultural_centers.centers.guro.address') %></p>
            </div>
            <a href="tel:02-6906-7700" class="bg-blue-100 text-blue-700 px-3 py-1 rounded-full text-sm font-medium hover:bg-blue-200">
              📞 02-6906-7700
            </a>
          </div>
          <div class="mt-3 flex flex-wrap gap-2">
            <span class="bg-emerald-100 text-emerald-700 px-2 py-1 rounded text-xs"><%= t('multicultural_centers.services.korean_class') %></span>
            <span class="bg-purple-100 text-purple-700 px-2 py-1 rounded text-xs"><%= t('multicultural_centers.services.bilingual_education') %></span>
            <span class="bg-amber-100 text-amber-700 px-2 py-1 rounded text-xs"><%= t('multicultural_centers.services.counseling') %></span>
          </div>
        </div>

        <!-- Yeongdeungpo -->
        <div class="bg-white border border-gray-200 rounded-lg p-4 hover:shadow-md transition-shadow">
          <div class="flex justify-between items-start">
            <div>
              <h3 class="font-semibold text-lg"><%= t('multicultural_centers.centers.yeongdeungpo.name') %></h3>
              <p class="text-gray-600 text-sm mt-1"><%= t('multicultural_centers.centers.yeongdeungpo.address') %></p>
            </div>
            <a href="tel:02-2636-4451" class="bg-blue-100 text-blue-700 px-3 py-1 rounded-full text-sm font-medium hover:bg-blue-200">
              📞 02-2636-4451
            </a>
          </div>
          <div class="mt-3 flex flex-wrap gap-2">
            <span class="bg-emerald-100 text-emerald-700 px-2 py-1 rounded text-xs"><%= t('multicultural_centers.services.korean_class') %></span>
            <span class="bg-blue-100 text-blue-700 px-2 py-1 rounded text-xs"><%= t('multicultural_centers.services.job_support') %></span>
            <span class="bg-amber-100 text-amber-700 px-2 py-1 rounded text-xs"><%= t('multicultural_centers.services.counseling') %></span>
          </div>
        </div>

        <!-- Geumcheon -->
        <div class="bg-white border border-gray-200 rounded-lg p-4 hover:shadow-md transition-shadow">
          <div class="flex justify-between items-start">
            <div>
              <h3 class="font-semibold text-lg"><%= t('multicultural_centers.centers.geumcheon.name') %></h3>
              <p class="text-gray-600 text-sm mt-1"><%= t('multicultural_centers.centers.geumcheon.address') %></p>
            </div>
            <a href="tel:02-803-7743" class="bg-blue-100 text-blue-700 px-3 py-1 rounded-full text-sm font-medium hover:bg-blue-200">
              📞 02-803-7743
            </a>
          </div>
          <div class="mt-3 flex flex-wrap gap-2">
            <span class="bg-emerald-100 text-emerald-700 px-2 py-1 rounded text-xs"><%= t('multicultural_centers.services.korean_class') %></span>
            <span class="bg-purple-100 text-purple-700 px-2 py-1 rounded text-xs"><%= t('multicultural_centers.services.bilingual_education') %></span>
          </div>
        </div>
      </div>
    </section>

    <!-- Gyeonggi Region -->
    <section>
      <h2 class="text-xl font-semibold mb-4 flex items-center gap-2">
        <span>🏛️</span>
        <%= t('multicultural_centers.regions.gyeonggi') %>
      </h2>

      <div class="grid gap-4">
        <!-- Ansan -->
        <div class="bg-white border border-gray-200 rounded-lg p-4 hover:shadow-md transition-shadow">
          <div class="flex justify-between items-start">
            <div>
              <h3 class="font-semibold text-lg"><%= t('multicultural_centers.centers.ansan.name') %></h3>
              <p class="text-gray-600 text-sm mt-1"><%= t('multicultural_centers.centers.ansan.address') %></p>
            </div>
            <a href="tel:031-599-1681" class="bg-blue-100 text-blue-700 px-3 py-1 rounded-full text-sm font-medium hover:bg-blue-200">
              📞 031-599-1681
            </a>
          </div>
          <div class="mt-3 flex flex-wrap gap-2">
            <span class="bg-emerald-100 text-emerald-700 px-2 py-1 rounded text-xs"><%= t('multicultural_centers.services.korean_class') %></span>
            <span class="bg-blue-100 text-blue-700 px-2 py-1 rounded text-xs"><%= t('multicultural_centers.services.job_support') %></span>
            <span class="bg-rose-100 text-rose-700 px-2 py-1 rounded text-xs"><%= t('multicultural_centers.services.legal_support') %></span>
          </div>
        </div>

        <!-- Suwon -->
        <div class="bg-white border border-gray-200 rounded-lg p-4 hover:shadow-md transition-shadow">
          <div class="flex justify-between items-start">
            <div>
              <h3 class="font-semibold text-lg"><%= t('multicultural_centers.centers.suwon.name') %></h3>
              <p class="text-gray-600 text-sm mt-1"><%= t('multicultural_centers.centers.suwon.address') %></p>
            </div>
            <a href="tel:031-257-8504" class="bg-blue-100 text-blue-700 px-3 py-1 rounded-full text-sm font-medium hover:bg-blue-200">
              📞 031-257-8504
            </a>
          </div>
          <div class="mt-3 flex flex-wrap gap-2">
            <span class="bg-emerald-100 text-emerald-700 px-2 py-1 rounded text-xs"><%= t('multicultural_centers.services.korean_class') %></span>
            <span class="bg-amber-100 text-amber-700 px-2 py-1 rounded text-xs"><%= t('multicultural_centers.services.counseling') %></span>
          </div>
        </div>
      </div>
    </section>

    <!-- Other Regions -->
    <section>
      <h2 class="text-xl font-semibold mb-4 flex items-center gap-2">
        <span>🏛️</span>
        <%= t('multicultural_centers.regions.other') %>
      </h2>

      <div class="grid gap-4">
        <!-- Busan -->
        <div class="bg-white border border-gray-200 rounded-lg p-4 hover:shadow-md transition-shadow">
          <div class="flex justify-between items-start">
            <div>
              <h3 class="font-semibold text-lg"><%= t('multicultural_centers.centers.busan.name') %></h3>
              <p class="text-gray-600 text-sm mt-1"><%= t('multicultural_centers.centers.busan.address') %></p>
            </div>
            <a href="tel:051-711-6290" class="bg-blue-100 text-blue-700 px-3 py-1 rounded-full text-sm font-medium hover:bg-blue-200">
              📞 051-711-6290
            </a>
          </div>
          <div class="mt-3 flex flex-wrap gap-2">
            <span class="bg-emerald-100 text-emerald-700 px-2 py-1 rounded text-xs"><%= t('multicultural_centers.services.korean_class') %></span>
            <span class="bg-blue-100 text-blue-700 px-2 py-1 rounded text-xs"><%= t('multicultural_centers.services.job_support') %></span>
          </div>
        </div>

        <!-- Daegu -->
        <div class="bg-white border border-gray-200 rounded-lg p-4 hover:shadow-md transition-shadow">
          <div class="flex justify-between items-start">
            <div>
              <h3 class="font-semibold text-lg"><%= t('multicultural_centers.centers.daegu.name') %></h3>
              <p class="text-gray-600 text-sm mt-1"><%= t('multicultural_centers.centers.daegu.address') %></p>
            </div>
            <a href="tel:053-219-8101" class="bg-blue-100 text-blue-700 px-3 py-1 rounded-full text-sm font-medium hover:bg-blue-200">
              📞 053-219-8101
            </a>
          </div>
          <div class="mt-3 flex flex-wrap gap-2">
            <span class="bg-emerald-100 text-emerald-700 px-2 py-1 rounded text-xs"><%= t('multicultural_centers.services.korean_class') %></span>
            <span class="bg-amber-100 text-amber-700 px-2 py-1 rounded text-xs"><%= t('multicultural_centers.services.counseling') %></span>
          </div>
        </div>
      </div>
    </section>
  </div>

  <!-- Info Box -->
  <div class="mt-8 bg-blue-50 border border-blue-200 rounded-lg p-4">
    <p class="text-blue-800 text-sm">
      <strong><%= t('multicultural_centers.info.title') %></strong><br>
      <%= t('multicultural_centers.info.description') %>
    </p>
  </div>

  <!-- National Portal Link -->
  <div class="mt-6 text-center">
    <a href="https://www.liveinkorea.kr" target="_blank" rel="noopener"
       class="inline-flex items-center gap-2 text-blue-600 hover:text-blue-800 font-medium">
      🌐 <%= t('multicultural_centers.national_portal') %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
      </svg>
    </a>
  </div>
</div>
