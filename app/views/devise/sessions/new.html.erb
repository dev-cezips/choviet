<div class="min-h-screen bg-gray-50 flex flex-col justify-center py-12 sm:px-6 lg:px-8">
  <div class="sm:mx-auto sm:w-full sm:max-w-md">
    <!-- Logo -->
    <div class="text-center">
      <span class="text-6xl">🏪</span>
      <h2 class="mt-4 text-3xl font-bold text-gray-900">
        Chào mừng đến Chợ Việt
      </h2>
      <p class="mt-2 text-sm text-gray-600">
        Cộng đồng người Việt tại Hàn Quốc
      </p>
    </div>
  </div>

  <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md">
    <div class="bg-white py-8 px-4 shadow-lg sm:rounded-xl sm:px-10">
      <%= form_for(resource, as: resource_name, url: session_path(resource_name), 
                   html: { 
                     class: "space-y-6", 
                     id: "login-form",
                     data: { turbo: false }
                   }) do |f| %>
        
        <% if flash[:alert] %>
          <div class="rounded-md bg-red-50 p-4 mb-4">
            <div class="flex">
              <div class="flex-shrink-0">
                <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
                </svg>
              </div>
              <div class="ml-3">
                <p class="text-sm font-medium text-red-800">
                  <%= flash[:alert] %>
                </p>
              </div>
            </div>
          </div>
        <% end %>
        
          <!-- Email -->
          <div>
            <%= f.label :email, class: "block text-sm font-medium text-gray-700" %>
            <div class="mt-1">
              <%= f.email_field :email, 
                  autofocus: true,
                  autocomplete: "email",
                  required: true,
                  placeholder: "nguyen@example.com",
                  class: "appearance-none block w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-gray-900 bg-white" %>
            </div>
          </div>

          <!-- Password -->
          <div>
            <%= f.label :password, class: "block text-sm font-medium text-gray-700" %>
            <div class="mt-1">
              <%= f.password_field :password,
                  autocomplete: "current-password",
                  required: true,
                  placeholder: "••••••••",
                  class: "appearance-none block w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-gray-900 bg-white" %>
            </div>
          </div>

          <!-- Remember me (always on) & Forgot password -->
          <div class="flex items-center justify-end">
            <%# 당근마켓처럼 항상 로그인 유지 - 체크박스 숨기고 항상 true %>
            <%= f.hidden_field :remember_me, value: "1" %>

            <%= link_to "Quên mật khẩu?", new_password_path(resource_name),
                class: "text-sm text-blue-600 hover:text-blue-700" %>
          </div>

          <!-- Submit -->
          <div>
            <%= f.submit "Đăng nhập", 
                class: "w-full flex justify-center py-3 px-4 border border-transparent rounded-lg shadow-sm text-sm font-medium text-white hover:opacity-90 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-all cursor-pointer",
                style: "background-color: #0068FF;",
                id: "login-submit-button" %>
          </div>
      <% end %>

      <!-- Divider -->
      <div class="mt-6">
        <div class="relative">
          <div class="absolute inset-0 flex items-center">
            <div class="w-full border-t border-gray-300"></div>
          </div>
          <div class="relative flex justify-center text-sm">
            <span class="px-2 bg-white text-gray-500">Hoặc đăng nhập với</span>
          </div>
        </div>

        <!-- Social login buttons -->
        <div class="mt-6 space-y-3">
          <% if devise_mapping.omniauthable? %>
            <% resource_class.omniauth_providers.each do |provider| %>
              <% if provider == :google_oauth2 %>
                <%= button_to user_google_oauth2_omniauth_authorize_path,
                    method: :post,
                    data: { turbo: false },
                    class: "w-full inline-flex justify-center items-center py-3 px-4 border border-gray-300 rounded-lg shadow-sm bg-white text-sm font-medium text-gray-700 hover:bg-gray-50 transition-all" do %>
                  <svg class="w-5 h-5 mr-2" viewBox="0 0 24 24">
                    <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                    <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                    <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                    <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                  </svg>
                  Google
                <% end %>
              <% elsif provider == :apple %>
                <%= button_to user_apple_omniauth_authorize_path,
                    method: :post,
                    data: { turbo: false },
                    class: "w-full inline-flex justify-center items-center py-3 px-4 border border-gray-300 rounded-lg shadow-sm bg-black text-sm font-medium text-white hover:bg-gray-900 transition-all" do %>
                  <svg class="w-5 h-5 mr-2" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09l.01-.01zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"/>
                  </svg>
                  Apple
                <% end %>
              <% end %>
            <% end %>
          <% end %>
        </div>

        <!-- Sign up link -->
        <div class="mt-6 text-center">
          <span class="text-sm text-gray-600">
            Chưa có tài khoản?
          </span>
          <%= link_to "Đăng ký ngay", new_registration_path(resource_name), 
              class: "ml-1 font-medium text-blue-600 hover:text-blue-700" %>
        </div>
      </div>

      <!-- Benefits -->
      <div class="mt-8 bg-gray-50 -mx-10 -mb-8 px-10 py-6 sm:rounded-b-xl">
        <h3 class="text-sm font-medium text-gray-900 mb-3"><%= t('features.join_benefits.title') %></h3>
        <ul class="space-y-2 text-sm text-gray-600">
          <li class="flex items-start">
            <span class="text-green-500 mr-2">✓</span>
            <span><%= t('features.join_benefits.marketplace') %></span>
          </li>
          <li class="flex items-start">
            <span class="text-green-500 mr-2">✓</span>
            <span><%= t('features.join_benefits.qa') %></span>
          </li>
          <li class="flex items-start">
            <span class="text-green-500 mr-2">✓</span>
            <span><%= t('features.join_benefits.connect') %></span>
          </li>
        </ul>
      </div>
    </div>
  </div>
</div>

