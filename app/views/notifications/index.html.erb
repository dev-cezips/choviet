<div class="max-w-2xl mx-auto px-4 py-6">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-900"><%= t('notifications.title', default: 'Thông báo') %></h1>
    <% if @notifications.any? %>
      <%= link_to t('notifications.mark_all_read', default: 'Đánh dấu tất cả đã đọc'),
          mark_all_read_notifications_path,
          method: :post,
          class: "text-sm text-blue-600 hover:text-blue-800" %>
    <% end %>
  </div>

  <% if @notifications.any? %>
    <div class="bg-white rounded-xl shadow-sm divide-y divide-gray-100">
      <% @notifications.each do |notification| %>
        <%= render "notification", notification: notification %>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-16">
      <div class="text-5xl mb-4">🔔</div>
      <p class="text-gray-500"><%= t('notifications.empty', default: 'Chưa có thông báo nào') %></p>
    </div>
  <% end %>
</div>
