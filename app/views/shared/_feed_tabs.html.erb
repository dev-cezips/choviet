<%# Tab navigation between Marketplace and Stories %>
<% active_tab ||= :marketplace %>

<div class="bg-white border-b border-gray-200 sticky top-0 z-10">
  <div class="max-w-screen-lg mx-auto">
    <nav class="flex" aria-label="Tabs">
      <!-- Marketplace Tab -->
      <%= link_to root_path,
          class: "flex-1 py-4 px-1 text-center border-b-2 font-medium text-sm transition-colors #{active_tab == :marketplace ? 'border-primary text-primary' : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300'}" do %>
        <span class="flex items-center justify-center gap-2">
          <span class="text-lg">🛍️</span>
          <span>Chợ</span>
        </span>
      <% end %>

      <!-- Stories Tab -->
      <%= link_to stories_path,
          class: "flex-1 py-4 px-1 text-center border-b-2 font-medium text-sm transition-colors #{active_tab == :stories ? 'border-amber-500 text-amber-600' : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300'}" do %>
        <span class="flex items-center justify-center gap-2">
          <span class="text-lg">📖</span>
          <span>Câu chuyện</span>
          <% stories_count = User.where.not(story: [nil, ""]).count %>
          <% if stories_count > 0 %>
            <span class="text-xs px-1.5 py-0.5 rounded-full <%= active_tab == :stories ? 'bg-amber-100 text-amber-700' : 'bg-gray-100 text-gray-600' %>">
              <%= stories_count %>
            </span>
          <% end %>
        </span>
      <% end %>
    </nav>
  </div>
</div>
