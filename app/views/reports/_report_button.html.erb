<% if current_user && reportable.reporter != current_user %>
  <% if reportable.reported_by?(current_user) %>
    <span class="text-xs text-gray-500">
      <%= t('reports.reported', default: 'Đã báo cáo') %>
    </span>
  <% else %>
    <%= link_to report_path_for(reportable),
        class: "text-sm text-red-600 hover:text-red-800 transition",
        data: { turbo_frame: "modal" } do %>
      <%= t('actions.report', default: 'Báo cáo') %>
    <% end %>
  <% end %>
<% end %>
