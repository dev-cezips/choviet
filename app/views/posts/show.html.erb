<div class="bg-gray-50">
  <!-- Images Section -->
  <%= render "posts/image_slider", images: @post.images %>
  
  <% unless @post.images.attached? && @post.images.any? %>
    <!-- No Image Placeholder -->
    <div class="relative bg-gray-100">
      <div class="h-64 md:h-96 flex items-center justify-center">
        <div class="text-center">
          <svg class="w-24 h-24 text-gray-400 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
          </svg>
          <p class="mt-2 text-sm text-gray-500">Không có hình ảnh</p>
        </div>
      </div>
    </div>
  <% end %>

  <div class="container mx-auto px-4 py-6 max-w-4xl">
    <!-- First Trade Banner -->
    <% if user_signed_in? && current_user.first_trade? && @post.user != current_user %>
      <div class="bg-gradient-to-r from-blue-50 to-indigo-50 border border-blue-200 rounded-lg p-4 mb-4 flex items-start gap-3">
        <span class="text-2xl">😊</span>
        <div class="flex-1">
          <p class="font-medium text-blue-900 mb-1">Chào mừng bạn đến với giao dịch đầu tiên!</p>
          <p class="text-sm text-blue-700">Chúng tôi sẽ hướng dẫn bạn để giao dịch thuận lợi.</p>
        </div>
      </div>
    <% end %>
    
    <!-- Post Info -->
    <div class="bg-white rounded-lg shadow-sm p-4 md:p-6">
      <!-- Title and Price -->
      <div class="flex items-start gap-2 mb-2">
        <h1 class="text-xl md:text-2xl font-bold text-gray-900"><%= @post.title %></h1>
        <% if @post.sold? %>
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-500 text-white flex-shrink-0">
            <%= t('posts.statuses.sold') %>
          </span>
        <% end %>
      </div>

      <% if @post.marketplace? && @post.product %>
        <p class="text-2xl font-bold <%= @post.sold? ? 'text-gray-400 line-through' : 'text-soft-coral' %> mb-4">
          <%= price_display(@post.product.price) %>
        </p>
      <% end %>
      
      <!-- Meta Info -->
      <div class="flex items-center gap-4 text-sm text-gray-500 mb-4">
        <div class="flex items-center gap-1">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
          </svg>
          <span>Lượt xem: <%= @post.views_count %></span>
        </div>
        <span>•</span>
        <span><%= time_ago_in_words(@post.created_at) %> trước</span>
      </div>
      
      <!-- Category Badge + Edit Button -->
      <div class="flex items-center justify-between mb-4">
        <%= category_badge(@post) %>
        <% if @post.user == current_user %>
          <%= link_to edit_post_path(@post), class: "inline-flex items-center gap-1 px-3 py-1.5 text-sm text-gray-600 bg-gray-100 rounded-lg hover:bg-gray-200" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
            </svg>
            <span>Sửa</span>
          <% end %>
        <% end %>
      </div>
      
      <!-- Content -->
      <div class="prose prose-gray max-w-none mb-6">
        <%= simple_format(@post.content) %>
      </div>
      
      <% if @post.marketplace? && @post.product&.condition.present? %>
        <!-- Product Condition -->
        <div class="bg-gray-50 rounded-lg p-4 mb-6">
          <p class="text-sm text-gray-600 mb-1"><%= t("products.condition_label", default: "Tình trạng") %></p>
          <p class="font-medium">
            <%= render "shared/badge",
                icon: product_condition_icon(@post.product.condition),
                label: product_condition_label(@post.product.condition),
                class_name: product_condition_badge_class(@post.product.condition) %>
          </p>
        </div>
      <% end %>
    </div>

    <!-- Low Reputation Warning -->
    <% if @post.user.low_reputation? %>
      <%= render "shared/alert_panel",
          variant: :tip,
          icon: "💡",
          title: "Lưu ý khi giao dịch",
          body: "Người dùng này đang xây dựng uy tín. Bạn có thể trao đổi thêm để hiểu rõ hơn trước khi quyết định.",
          class_name: "mt-4 mb-3" %>
    <% end %>
    
    <!-- Seller Info -->
    <div class="bg-white rounded-lg shadow-sm p-4 md:p-6 mt-4">
      <h3 class="font-semibold text-gray-900 mb-4">Thông tin người bán</h3>
      
      <%= link_to user_path(@post.user), class: "flex items-center gap-3" do %>
        <% if @post.user.avatar.attached? %>
          <%= image_tag @post.user.avatar, class: "w-12 h-12 rounded-full object-cover" %>
        <% elsif @post.user.avatar_url.present? %>
          <%= image_tag @post.user.avatar_url, class: "w-12 h-12 rounded-full object-cover" %>
        <% else %>
          <div class="w-12 h-12 rounded-full bg-blue-100 flex items-center justify-center text-blue-600 font-bold">
            <%= @post.user.display_name.first.upcase %>
          </div>
        <% end %>
        <div class="flex-1">
          <p class="font-semibold text-gray-900"><%= @post.user.display_name %></p>
          <p class="text-xs text-gray-500">Tham gia: <%= l(@post.user.created_at.to_date, format: :short) %></p>
        </div>
        <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
        </svg>
      <% end %>
      
      <!-- Trust Summary -->
      <div class="mt-3 px-2">
        <p class="text-sm text-gray-600"><%= @post.user.trust_summary(context: :post) %></p>
        <% if @post.user.trust_hint(context: :post).present? %>
          <p class="text-xs text-gray-500 mt-1"><%= @post.user.trust_hint(context: :post) %></p>
        <% end %>
      </div>

      <!-- Seller Story -->
      <% if @post.user.story.present? %>
        <div class="mt-4 bg-gradient-to-br from-amber-50 to-orange-50 rounded-lg p-3 border border-amber-200">
          <div class="flex items-center gap-2 mb-2">
            <span class="text-lg">📖</span>
            <span class="text-sm font-medium text-gray-700">Câu chuyện người bán</span>
          </div>
          <p class="text-sm text-gray-600 leading-relaxed line-clamp-3"><%= @post.user.story %></p>
          <% if @post.user.story.length > 150 %>
            <%= link_to user_path(@post.user), class: "text-xs text-primary hover:underline mt-1 inline-block" do %>
              Xem thêm →
            <% end %>
          <% end %>
        </div>
      <% end %>

      <!-- 문의하기 Button (Chat) - Hide if sold -->
      <% if @post.user != current_user && user_signed_in? && !@post.sold? %>
        <div class="mt-3">
          <%= button_to dm_post_path(@post), method: :post,
              class: "w-full flex items-center justify-center gap-2 px-4 py-2 bg-green-50 text-green-600 rounded-lg font-medium hover:bg-green-100 transition-colors" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
            </svg>
            <span><%= t('inquiries.title') %></span>
          <% end %>
        </div>
      <% elsif @post.sold? && @post.user != current_user %>
        <div class="mt-3 text-center py-3 bg-gray-100 rounded-lg text-gray-500 font-medium">
          <%= t('posts.mark_sold.sold_notice') %>
        </div>
      <% end %>
      
      <% if @post.location %>
        <div class="mt-4 pt-4 border-t">
          <div class="flex items-center gap-2 text-sm text-gray-600">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
            <span><%= location_display(@post.location) %></span>
          </div>
        </div>
      <% end %>
    </div>

    <!-- Action Buttons (Mobile) - Above bottom nav -->
    <div class="fixed left-0 right-0 bg-white border-t p-4 md:hidden shadow-lg" style="bottom: 56px;">
      <% if @post.user == current_user %>
        <div class="flex gap-3">
          <div id="post_likes_<%= @post.id %>" class="flex-shrink-0">
            <%= render partial: 'posts/like_button_detail', locals: { post: @post } %>
          </div>
          <% if @post.marketplace? && !@post.sold? %>
            <%= button_to mark_sold_post_path(@post), method: :patch,
                data: { turbo_confirm: t('posts.mark_sold.confirm') },
                class: "flex-1 bg-blue-600 text-white rounded-lg py-3 font-medium text-center min-h-[44px] flex items-center justify-center hover:bg-blue-700 transition-colors" do %>
              <span><%= t('posts.mark_sold.button') %></span>
            <% end %>
          <% elsif @post.sold? %>
            <div class="flex-1 bg-gray-300 text-gray-600 rounded-lg py-3 font-medium text-center min-h-[44px] flex items-center justify-center">
              <%= t('posts.statuses.sold') %>
            </div>
          <% else %>
            <%= link_to "Chỉnh sửa", edit_post_path(@post),
                class: "flex-1 bg-gray-100 text-gray-700 rounded-lg py-3 font-medium text-center min-h-[44px] flex items-center justify-center" %>
          <% end %>
        </div>
      <% else %>
        <div class="flex gap-3">
          <div id="post_likes_<%= @post.id %>" class="flex-shrink-0">
            <%= render partial: 'posts/like_button_detail', locals: { post: @post } %>
          </div>
          <% if @post.sold? %>
            <div class="flex-1 bg-gray-300 text-gray-600 rounded-lg py-3 font-bold text-center min-h-[44px] flex items-center justify-center">
              <%= t('posts.statuses.sold') %>
            </div>
          <% else %>
            <%# 문의하기 버튼 - Primary CTA %>
            <%= button_to dm_post_path(@post), method: :post,
                class: "flex-1 flex items-center justify-center gap-2 px-4 py-3 bg-green-600 text-white rounded-lg font-bold min-h-[44px] hover:bg-green-700 transition-colors" do %>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
              </svg>
              <span>Liên hệ người bán</span>
            <% end %>
          <% end %>
        </div>
      <% end %>
    </div>

    <!-- Desktop Action Buttons -->
    <div class="hidden md:block bg-white rounded-lg shadow-sm p-6 mt-4">
      <div class="flex gap-3">
        <div id="post_likes_desktop_<%= @post.id %>" class="flex-shrink-0">
          <%= render partial: 'posts/like_button_detail', locals: { post: @post } %>
        </div>

        <% if @post.user == current_user %>
          <% if @post.marketplace? && !@post.sold? %>
            <%= button_to mark_sold_post_path(@post), method: :patch,
                data: { turbo_confirm: t('posts.mark_sold.confirm') },
                class: "flex-1 bg-blue-600 hover:bg-blue-700 text-white rounded-lg py-3 font-medium text-center transition cursor-pointer" do %>
              <%= t('posts.mark_sold.button') %>
            <% end %>
          <% elsif @post.sold? %>
            <div class="flex-1 bg-gray-300 text-gray-600 rounded-lg py-3 font-medium text-center">
              <%= t('posts.statuses.sold') %>
            </div>
          <% else %>
            <%= link_to "Chỉnh sửa", edit_post_path(@post),
                class: "flex-1 bg-gray-100 hover:bg-gray-200 text-gray-700 rounded-lg py-3 font-medium text-center transition" %>
          <% end %>
          <%= button_to "Xóa bài", @post, method: :delete,
              data: { turbo_confirm: "Bạn chắc chắn muốn xóa?" },
              class: "px-6 py-3 bg-red-600 hover:bg-red-700 text-white rounded-lg font-medium transition cursor-pointer" %>
        <% else %>
          <% if @post.sold? %>
            <div class="flex-1 bg-gray-300 text-gray-600 rounded-lg py-3 font-bold text-center min-h-[44px] flex items-center justify-center">
              <%= t('posts.statuses.sold') %>
            </div>
          <% else %>
            <%# 문의하기 버튼 - Primary CTA %>
            <%= button_to dm_post_path(@post), method: :post,
                class: "flex-1 flex items-center justify-center gap-2 px-6 py-3 bg-green-600 text-white rounded-lg font-bold hover:bg-green-700 transition-colors min-h-[44px]" do %>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
              </svg>
              <span>Liên hệ người bán</span>
            <% end %>
          <% end %>
        <% end %>
      </div>
    </div>

    <!-- More Menu (Report) -->
    <% if @post.user != current_user %>
      <div class="text-center mt-6">
        <%= link_to new_post_report_path(@post),
            data: turbo_native_app? ? {} : { turbo_frame: "modal" },
            class: "inline-flex items-center gap-2 text-sm text-gray-500 hover:text-red-600" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
          </svg>
          Báo cáo bài viết
        <% end %>
      </div>
    <% end %>

    <!-- Related Posts -->
    <div class="bg-white rounded-lg shadow-sm p-4 md:p-6 mt-6 mb-24 md:mb-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Tin đăng khác của người bán</h2>
      <div class="space-y-3">
        <% @post.user.posts.where.not(id: @post.id).limit(3).each do |post| %>
          <%= link_to post, class: "block p-3 hover:bg-gray-50 rounded-lg transition-colors" do %>
            <div class="flex justify-between items-start">
              <div class="flex-1">
                <h3 class="font-medium text-gray-900"><%= post.title %></h3>
                <p class="text-sm text-gray-600 mt-1"><%= truncate(post.content, length: 60) %></p>
              </div>
              <% if post.marketplace? && post.product %>
                <span class="text-soft-coral font-medium whitespace-nowrap ml-3">
                  <%= price_display(post.product.price) %>
                </span>
              <% end %>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</div>

<!-- Lightbox Modal (분리된 컴포넌트) -->
<%= render "shared/lightbox" %>