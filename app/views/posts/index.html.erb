<!-- DEBUG: Current locale = <%= I18n.locale %> -->

<!-- Identity Banner -->
<div class="bg-gradient-to-r from-primary to-red-500 text-white px-4 py-3 text-center">
  <p class="text-sm font-medium"><%= t('tagline_detail') %></p>
</div>

<!-- Tab Navigation -->
<%= render "shared/feed_tabs", active_tab: :marketplace %>

<!-- Search and Filters -->
<%= render "posts/search_filters", url: @search_url %>

<div class="max-w-screen-lg mx-auto">

  <!-- Location Info Bar -->
  <% if user_signed_in? && current_user.has_location? %>
    <div class="bg-blue-50 px-4 py-2 flex items-center justify-between">
      <div class="flex items-center gap-2 text-sm text-blue-800">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
        </svg>
        <span>Vị trí: <%= location_display(current_user.location) %> • Hiển thị tất cả bài viết</span>
      </div>
    </div>
  <% end %>

  <!-- Posts List -->
  <turbo-frame id="posts_list">
    <div class="px-4 py-4 space-y-3">
      <% if @keyword.present? && @posts.empty? %>
        <!-- No Search Results -->
        <div class="text-center py-12">
          <div class="text-6xl mb-4">🔍</div>
          <h3 class="text-lg font-medium text-gray-900 mb-2">Không tìm thấy kết quả</h3>
          <p class="text-gray-500 mb-4">Không có bài viết nào với từ khóa "<%= @keyword %>"</p>
          <%= link_to "Xóa tìm kiếm", posts_path(type: params[:type]), 
              class: "text-zalo-blue hover:text-blue-700 font-medium" %>
        </div>
      <% elsif @posts.empty? %>
        <!-- Empty State - Section-specific -->
        <div class="text-center py-12">
          <% current_type = params[:type] %>
          <% case current_type %>
          <% when "question" %>
            <div class="text-6xl mb-4">❓</div>
            <h3 class="text-lg font-medium text-gray-900 mb-2"><%= t('posts.empty.question_title', default: 'Chưa có câu hỏi nào') %></h3>
            <p class="text-gray-500 mb-4"><%= t('posts.empty.question_desc', default: 'Hãy là người đầu tiên đặt câu hỏi!') %></p>
            <% if user_signed_in? %>
              <%= link_to new_post_path(type: "question"),
                  class: "inline-flex items-center gap-2 bg-blue-600 text-white px-5 py-3 rounded-full font-medium hover:bg-blue-700 transition-colors shadow-lg" do %>
                <span class="text-xl">❓</span>
                <span><%= t('posts.actions.ask_question', default: 'Đặt câu hỏi') %></span>
              <% end %>
            <% else %>
              <%= link_to new_user_session_path,
                  class: "inline-flex items-center gap-2 bg-blue-600 text-white px-5 py-3 rounded-full font-medium hover:bg-blue-700 transition-colors shadow-lg" do %>
                <span class="text-xl">❓</span>
                <span><%= t('posts.actions.login_to_ask', default: 'Đăng nhập để hỏi') %></span>
              <% end %>
            <% end %>
          <% when "free_talk" %>
            <div class="text-6xl mb-4">💬</div>
            <h3 class="text-lg font-medium text-gray-900 mb-2"><%= t('posts.empty.free_talk_title', default: 'Chưa có bài viết nào') %></h3>
            <p class="text-gray-500 mb-4"><%= t('posts.empty.free_talk_desc', default: 'Chia sẻ suy nghĩ của bạn với cộng đồng!') %></p>
            <% if user_signed_in? %>
              <%= link_to new_post_path(type: "free_talk"),
                  class: "inline-flex items-center gap-2 bg-purple-600 text-white px-5 py-3 rounded-full font-medium hover:bg-purple-700 transition-colors shadow-lg" do %>
                <span class="text-xl">💬</span>
                <span><%= t('posts.actions.write_post', default: 'Viết bài') %></span>
              <% end %>
            <% else %>
              <%= link_to new_user_session_path,
                  class: "inline-flex items-center gap-2 bg-purple-600 text-white px-5 py-3 rounded-full font-medium hover:bg-purple-700 transition-colors shadow-lg" do %>
                <span class="text-xl">💬</span>
                <span><%= t('posts.actions.login_to_write', default: 'Đăng nhập để viết') %></span>
              <% end %>
            <% end %>
          <% when "marketplace" %>
            <div class="text-6xl mb-4">🛍️</div>
            <h3 class="text-lg font-medium text-gray-900 mb-2"><%= t('posts.empty.marketplace_title', default: 'Chưa có sản phẩm nào') %></h3>
            <p class="text-gray-500 mb-4"><%= t('posts.empty.marketplace_desc', default: 'Hãy là người đầu tiên đăng bán!') %></p>
            <% if user_signed_in? %>
              <%= link_to new_post_path(type: "marketplace"),
                  class: "inline-flex items-center gap-2 bg-rose-500 text-white px-5 py-3 rounded-full font-medium hover:bg-rose-600 transition-colors shadow-lg" do %>
                <span class="text-xl">🛍️</span>
                <span><%= t('posts.actions.sell_item', default: 'Đăng bán') %></span>
              <% end %>
            <% else %>
              <%= link_to new_user_session_path,
                  class: "inline-flex items-center gap-2 bg-rose-500 text-white px-5 py-3 rounded-full font-medium hover:bg-rose-600 transition-colors shadow-lg" do %>
                <span class="text-xl">🛍️</span>
                <span><%= t('posts.actions.login_to_sell', default: 'Đăng nhập để bán') %></span>
              <% end %>
            <% end %>
          <% else %>
            <!-- All posts / no filter -->
            <div class="text-6xl mb-4">📭</div>
            <h3 class="text-lg font-medium text-gray-900 mb-2"><%= t('posts.empty.all_title', default: 'Chưa có bài viết nào') %></h3>
            <p class="text-gray-500 mb-4"><%= t('posts.empty.all_desc', default: 'Hãy là người đầu tiên đăng bài!') %></p>
            <% if user_signed_in? %>
              <div class="flex flex-wrap justify-center gap-3">
                <%= link_to new_post_path(type: "question"),
                    class: "inline-flex items-center gap-2 bg-blue-600 text-white px-4 py-2 rounded-full font-medium hover:bg-blue-700 transition-colors shadow" do %>
                  <span>❓</span>
                  <span><%= t('posts.actions.ask_question', default: 'Đặt câu hỏi') %></span>
                <% end %>
                <%= link_to new_post_path(type: "marketplace"),
                    class: "inline-flex items-center gap-2 bg-rose-500 text-white px-4 py-2 rounded-full font-medium hover:bg-rose-600 transition-colors shadow" do %>
                  <span>🛍️</span>
                  <span><%= t('posts.actions.sell_item', default: 'Đăng bán') %></span>
                <% end %>
                <%= link_to new_post_path(type: "free_talk"),
                    class: "inline-flex items-center gap-2 bg-purple-600 text-white px-4 py-2 rounded-full font-medium hover:bg-purple-700 transition-colors shadow" do %>
                  <span>💬</span>
                  <span><%= t('posts.actions.write_post', default: 'Viết bài') %></span>
                <% end %>
              </div>
            <% else %>
              <%= link_to new_user_session_path,
                  class: "inline-flex items-center gap-2 bg-blue-600 text-white px-5 py-3 rounded-full font-medium hover:bg-blue-700 transition-colors shadow-lg" do %>
                <span><%= t('posts.actions.login_to_post', default: 'Đăng nhập để đăng bài') %></span>
              <% end %>
            <% end %>
          <% end %>
        </div>
      <% else %>
        <% @posts.each do |post| %>
          <%= link_to post, class: "block", data: { turbo: false } do %>
            <article class="bg-pure-white rounded-card shadow-card hover:shadow-card-hover transition-shadow p-4 flex gap-3">
              <!-- Thumbnail -->
              <div class="flex-shrink-0 relative">
                <% if post.images.attached? && post.images.any? %>
                  <%= image_tag post.images.first.variant(resize_to_fill: [200, 200], saver: { quality: 75 }),
                      class: "w-24 h-24 rounded-lg object-cover",
                      loading: "lazy",
                      onerror: "this.style.display='none'; this.nextElementSibling.style.display='flex';" %>
                  <div class="w-24 h-24 rounded-lg bg-gray-100 items-center justify-center hidden">
                    <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                    </svg>
                  </div>
                <% else %>
                  <div class="w-24 h-24 rounded-lg bg-gray-100 flex items-center justify-center">
                    <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                    </svg>
                  </div>
                <% end %>
              </div>

              <!-- Content -->
              <div class="flex-1 min-w-0">
                <div class="flex items-start justify-between gap-2">
                  <div class="flex-1">
                    <h3 class="font-semibold text-charcoal line-clamp-1">
                      <%= post.title %>
                    </h3>
                    
                    <% if post.marketplace? && post.product %>
                      <p class="text-lg font-bold text-soft-coral mt-1">
                        <%= price_display(post.product.price) %>
                      </p>
                    <% end %>
                    
                    <p class="text-sm text-gray-500 mt-1 line-clamp-2">
                      <%= truncate(post.content, length: 50) %>
                    </p>
                  </div>
                  
                  <%= category_badge(post) %>
                </div>
                
                <!-- Meta info and actions -->
                <div class="flex items-center justify-between mt-2">
                  <div class="flex items-center gap-3 text-sm text-gray-500">
                    <span><%= post.user.name || "Người dùng" %></span>
                    <span>•</span>
                    <span><%= time_ago_in_words(post.created_at) %> trước</span>
                    <% if post.location %>
                      <span>•</span>
                      <span><%= post.location.name %></span>
                    <% end %>
                  </div>
                  
                  <div class="flex items-center gap-2">
                    <!-- Views -->
                    <span class="inline-flex items-center gap-1 text-sm text-gray-500">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                      </svg>
                      <%= post.views_count %>
                    </span>
                    
                    <!-- Favorite button -->
                    <%= render "posts/favorite_button", post: post %>
                  </div>
                </div>
              </div>
            </article>
          <% end %>
        <% end %>
      <% end %>
    </div>

    <!-- Pagination -->
    <% if @posts.respond_to?(:total_pages) && @posts.total_pages > 1 %>
      <div class="px-4 pb-4">
        <div class="flex justify-center">
          <%= paginate @posts, params: request.query_parameters %>
        </div>
      </div>
    <% end %>
  </turbo-frame>
</div>

<style>
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
</style>