<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Cho Viet" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <!-- Google Font: Be Vietnam Pro -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;700&display=swap" rel="stylesheet">
    
    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag "application", "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
    
    <style>
      /* Force white background */
      html, body {
        background-color: #ffffff !important;
        background: #ffffff !important;
      }

      /* Ensure main content is white */
      main, .bg-off-white, .bg-gray-50 {
        background-color: #ffffff !important;
      }

      /* Turbo Progress Bar */
      .turbo-progress-bar {
        position: fixed;
        top: 0;
        left: 0;
        height: 3px;
        background: linear-gradient(90deg, #0068FF, #00C6FF);
        z-index: 9999999;
        transition: width 0.3s ease-out, opacity 0.15s ease-in;
        box-shadow: 0 0 10px rgba(0, 104, 255, 0.5);
      }

      /* Loading Overlay */
      .loading-overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(255, 255, 255, 0.8);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 9999998;
        opacity: 0;
        visibility: hidden;
        transition: opacity 0.2s, visibility 0.2s;
      }
      .loading-overlay.active {
        opacity: 1;
        visibility: visible;
      }

      /* Spinner */
      .spinner {
        width: 40px;
        height: 40px;
        border: 3px solid #e5e7eb;
        border-top-color: #0068FF;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
      }
      @keyframes spin {
        to { transform: rotate(360deg); }
      }

      /* Button loading state */
      button[disabled], input[type="submit"][disabled] {
        opacity: 0.7;
        cursor: wait;
      }
    </style>
  </head>

  <body class="font-vietnam" style="<%= turbo_native_app? ? 'padding-top: env(safe-area-inset-top, 0px);' : 'padding-top: 120px !important;' %> background-color: #ffffff !important;">
    <!-- Global Loading Overlay -->
    <div id="loading-overlay" class="loading-overlay">
      <div class="spinner"></div>
    </div>
    <% if turbo_native_app? %>
      <!-- Turbo Native: Minimal header with profile access -->
      <div class="bg-white border-b border-gray-200 px-4 py-3 flex items-center justify-between">
        <%= link_to posts_path, class: "text-lg font-bold text-gray-900 flex items-center gap-2" do %>
          <%= image_tag "icon.png", alt: "Chợ Việt", class: "h-7 w-7", style: "object-fit: contain;" %>
          Chợ Việt
        <% end %>
        <% if user_signed_in? %>
          <%= link_to me_path, class: "p-2 text-gray-600 hover:text-gray-900" do %>
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
            </svg>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <%= render "layouts/header" %>
    <% end %>

    <!-- Main content wrapper -->
    <div>
      <%= turbo_frame_tag "flash" do %>
        <%= render "shared/flash" %>
      <% end %>

      <!-- Main content -->
      <main>
        <%= yield %>
      </main>
    </div>
    
    <!-- Footer -->
    <footer class="bg-gray-100 border-t border-gray-200 mt-20 pb-16 lg:pb-0">
      <div class="max-w-7xl mx-auto px-4 py-8">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <!-- About -->
          <div>
            <div class="flex items-center gap-2 mb-4">
              <%= image_tag "icon.png", alt: "Chợ Việt", class: "h-10 w-10", style: "object-fit: contain;" %>
              <h3 class="text-lg font-semibold"><%= t('footer.about.title') %></h3>
            </div>
            <p class="text-sm text-gray-600">
              <%= t('footer.about.description') %>
            </p>
          </div>
          
          <!-- Links -->
          <div>
            <h3 class="text-lg font-semibold mb-4"><%= t('footer.links.title') %></h3>
            <ul class="space-y-2">
              <li>
                <%= link_to t('footer.links.multicultural_centers'), multicultural_centers_path, class: "text-sm text-gray-600 hover:text-gray-900" %>
              </li>
              <li>
                <%= link_to t('footer.links.public_services'), public_services_path, class: "text-sm text-gray-600 hover:text-gray-900" %>
              </li>
              <li>
                <%= link_to t('footer.links.privacy'), privacy_path, class: "text-sm text-gray-600 hover:text-gray-900" %>
              </li>
              <li>
                <%= link_to t('footer.links.terms'), terms_path, class: "text-sm text-gray-600 hover:text-gray-900" %>
              </li>
            </ul>
          </div>
          
          <!-- Operated by -->
          <div>
            <h3 class="text-lg font-semibold mb-4"><%= t('footer.contact.title') %></h3>
            <p class="text-sm text-gray-600">
              <%= t('footer.contact.operator') %>
            </p>
          </div>
        </div>
        
        <div class="border-t border-gray-200 mt-8 pt-8 text-center">
          <p class="text-sm text-gray-500">
            <%= t('footer.copyright').html_safe %>
          </p>
        </div>
      </div>
    </footer>
    
    <!-- Modal frames (modal = new standard, report_modal = legacy compat) -->
    <%= turbo_frame_tag "modal" %>
    <%= turbo_frame_tag "report_modal" %>

    <%= render "shared/rate_limit_notice" if defined?(request) %>

    <!-- Mobile Bottom Navigation -->
    <% unless turbo_native_app? || devise_controller? %>
      <%= render "layouts/mobile_bottom_nav" %>
    <% end %>

    <% if turbo_native_app? && !user_signed_in? && !devise_controller? %>
      <!-- Turbo Native: Clear login bar at bottom -->
      <div class="fixed bottom-0 left-0 right-0 bg-white border-t border-gray-200 px-4 py-3 z-40" style="padding-bottom: env(safe-area-inset-bottom, 12px);">
        <div class="flex items-center justify-between max-w-screen-lg mx-auto">
          <span class="text-sm text-gray-600"><%= t('auth.login_prompt', default: 'Đăng nhập để đăng bài') %></span>
          <div class="flex gap-2">
            <%= link_to t('nav.sign_in'), new_user_session_path, class: "px-4 py-2 text-sm font-medium text-blue-600 hover:text-blue-700" %>
            <%= link_to t('nav.sign_up'), new_user_registration_path, class: "px-4 py-2 text-sm font-medium text-white rounded-lg", style: "background-color: #0068FF;" %>
          </div>
        </div>
      </div>
    <% end %>
  </body>
</html>
